// Jenkins pipeline for the flight regression workflow.
pipeline {
    // Any agent can pick up the job, but the first stage confirms it is usable.
    agent any

    options {
        // Timestamps make CI logs easier to read back later.
        timestamps()
        // Avoid overlapping runs that could compete for the same workspace paths.
        disableConcurrentBuilds()
    }

    environment {
        // Unbuffered Python output keeps training logs visible in real time.
        PYTHONUNBUFFERED = '1'
        // Build the virtual environment inside the workspace so cleanup stays local.
        VENV_DIR = "${WORKSPACE}/.jenkins-venv"
        // Keep all validation artifacts under one folder that Jenkins can archive.
        JENKINS_OUTPUT_DIR = "${WORKSPACE}/jenkins_artifacts"
    }

    stages {
        stage('Agent Check') {
            steps {
                script {
                    // Airflow is not part of this job, but the shell scripts and Docker checks assume Linux.
                    if (!isUnix()) {
                        error('This Jenkins pipeline is set up for a Linux Jenkins agent with Python 3 and optional Docker support.')
                    }
                }

                sh '''
                    # Stop right away if any command in this block fails.
                    set -e

                    # Confirm the agent has Python 3 before the setup stage starts.
                    python3 --version

                    # Create the artifact folder up front so later stages can write into it.
                    mkdir -p "$JENKINS_OUTPUT_DIR"
                '''
            }
        }

        stage('Workspace Check') {
            steps {
                sh '''
                    # Treat missing repo files as an immediate pipeline failure.
                    set -e

                    # Check the key files that the flight workflow depends on.
                    test -f README.md
                    test -f requirements.txt
                    test -f Dockerfile
                    test -f Dockerfile.mlops
                    test -f Dockerfile.streamlit
                    test -f docker-compose.yml
                    test -f airflow/dags/flight_price_regression_pipeline.py
                    test -f training/train_flight_price_regression_mlflow.py
                    test -f dataset/travel_capstone/flights.csv
                    test -f flask_apps/flight_price_flask_app/app.py
                    test -f streamlit/flight_price_app.py
                '''
            }
        }

        stage('Set Up Python') {
            steps {
                sh '''
                    # Use a fresh environment so the CI run is isolated from the agent state.
                    set -e
                    python3 -m venv "$VENV_DIR"

                    # Activate the environment and install the project dependencies.
                    . "$VENV_DIR/bin/activate"
                    python -m pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Validate Flight Workflow') {
            steps {
                sh '''
                    # Reuse the same virtual environment from the setup stage.
                    set -e
                    . "$VENV_DIR/bin/activate"

                    # Run the local validation helper in a Jenkins-specific output folder.
                    python scripts/validate_flight_regression_workflow.py --output-dir "$JENKINS_OUTPUT_DIR/flight_validation"
                '''
            }
        }

        stage('Validate Docker Assets') {
            steps {
                script {
                    // Docker is helpful here, but the pipeline still provides value without it.
                    def dockerStatus = sh(script: 'docker --version >/dev/null 2>&1', returnStatus: true)

                    if (dockerStatus != 0) {
                        echo 'Docker is not available on this Jenkins agent, so the Docker validation stage is being skipped.'
                        sh '''
                            # Leave a clear note in the archived artifacts when Docker is skipped.
                            set -e
                            cat <<'EOF' > "$JENKINS_OUTPUT_DIR/docker-validation-note.txt"
                            Docker validation was skipped because Docker was not available on this Jenkins agent.
                            The Python training workflow and repository structure were still validated.
                            EOF
                        '''
                    } else {
                        sh '''
                            # Validate the compose file and build every image the flight workflow depends on.
                            set -e
                            docker compose --profile mlops config > "$JENKINS_OUTPUT_DIR/docker-compose-resolved.yml"

                            docker build -t voyage-flight-api-jenkins -f Dockerfile .
                            docker build -t voyage-flight-streamlit-jenkins -f Dockerfile.streamlit .
                            docker build -t voyage-flight-mlops-jenkins -f Dockerfile.mlops .
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if (isUnix()) {
                    sh '''
                        # Remove temporary CI images so repeated runs do not leave clutter on the agent.
                        docker image rm -f voyage-flight-api-jenkins >/dev/null 2>&1 || true
                        docker image rm -f voyage-flight-streamlit-jenkins >/dev/null 2>&1 || true
                        docker image rm -f voyage-flight-mlops-jenkins >/dev/null 2>&1 || true
                    '''
                }
            }

            // Archive whatever the run produced so the build record stays useful even on failure.
            archiveArtifacts artifacts: 'jenkins_artifacts/**', allowEmptyArchive: true, fingerprint: true
        }
    }
}
